<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cooking.core.mapper.UserMapper">

    <select id="findPage" resultType="com.cooking.core.entity.UserEntity">
        select * from tbl_user where 1=1
        <if test="params.search != null">
            and user_name like concat('%',#{params.search},'%')
        </if>
        order by create_time desc
    </select>
</mapper>
