<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cooking.core.mapper.DishAppraisesMapper">

    <select id="findPage" resultType="com.cooking.core.entity.DishAppraisesEntity">
        select * from tbl_dish_appraises where 1=1
        <if test="params.userId != null">
            and user_id = #{params.userId}
        </if>
        <if test="params.dishId != null">
            and dish_id = #{params.dishId}
        </if>

        order by create_time desc
    </select>
</mapper>
