<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cooking.core.mapper.DishMapper">

    <select id="findPage" resultType="com.cooking.core.entity.DishEntity">
        select * from tbl_dish where 1=1
        <if test="params.dishIds != null and params.dishIds.size() > 0">
            and id in
            <foreach item="item" collection="params.dishIds" separator="," open="(" close=")" index="">
                #{item}
            </foreach>
        </if>
        <if test="params.search != null and params.search != ''">
            and name like concat('%',#{params.search},'%')
        </if>
        <if test="params.checkStatus != null and params.checkStatus != ''">
            and check_status = #{params.checkStatus}
        </if>
        <if test="params.withVideo != null and params.withVideo == true">
            and videoPath is not null
        </if>

        <if test="params.labelId != null and params.labelId != '' and params.labelId != 0">
            and exists(select 1 from tbl_dish_label_rel where dish_id = tbl_dish.id and label_id = #{params.labelId})
        </if>


        <choose>
            <when test="(params.sortBy != null and params.sortBy != '') and (params.sortMethod != null and params.sortMethod != '')">
                order by
                <choose>
                    <when test="params.sortBy == 'time'">create_time</when>
                    <when test="params.sortBy == 'activity'">active_val</when>
                    <when test="params.sortBy == 'popular_val'">popular_val</when>
                    <otherwise>create_time</otherwise>
                </choose>
                <choose>
                    <when test="params.sortMethod == 'asc' or params.sortMethod == 'ASC'">asc</when>
                    <otherwise>desc</otherwise>
                </choose>
            </when>
            <otherwise>
                order by create_time desc
            </otherwise>
        </choose>


    </select>
</mapper>
