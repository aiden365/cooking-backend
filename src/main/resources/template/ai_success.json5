{
  //成功标识，当菜品合法且能够给出菜品制作过程时固定返回success
  "status": "success",
  //烹饪时常（预估）
  "cooking_time": "30分钟",
  //食材列表
  "materials": [
    {
      "name": "食材名",
      "dosage": "用量",
      "preDeal": "预处理方式"
    }
  ],
  //调料列表
  "flavors": [
    {
      "name": "调料名",
      "dosage": "用量（如：250g）"
    }
  ],
  //制作步骤，过于复杂的步骤可以分解成多个步骤给出
  "steps": [
    {
      "step_number": 1,
      "instruction": "具体动作"
    }
  ],
  //小贴士
  "tips": "给出友好的制作建议"
}