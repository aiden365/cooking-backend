{
  "菜名": "西红柿炒鸡蛋",
  "主要食材": {
    "主料": [
      {
        "名称": "西红柿",
        "数量": "2-3个（中等大小）",
        "处理方式": "洗净切块"
      },
      {
        "名称": "鸡蛋",
        "数量": "3-4个",
        "处理方式": "打入碗中，加少许盐搅拌均匀"
      }
    ],
    "调料": [
      {
        "名称": "食用油",
        "数量": "适量"
      },
      {
        "名称": "盐",
        "数量": "适量"
      },
      {
        "名称": "糖",
        "数量": "少许（提鲜）"
      },
      {
        "名称": "葱花",
        "数量": "少许（可选）"
      }
    ]
  },
  "制作步骤": [
    {
      "step_number": 1,
      "instruction": "热锅凉油，倒入打好的鸡蛋液，用中火炒至凝固后盛出备用。"
    },
    {
      "step_number": 2,
      "instruction": "再倒入适量油，放入西红柿翻炒，炒至出沙汁后加入少许盐和糖调味。"
    },
    {
      "step_number": 3,
      "instruction": "将炒好的鸡蛋倒入锅中与西红柿混合，翻炒均匀，撒上葱花即可出锅。"
    }
  ],
  "小贴士": "可根据个人口味调整糖的用量，喜欢酸甜口味可增加西红柿数量。"
}